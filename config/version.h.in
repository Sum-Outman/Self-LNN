/* M-002修复: 统一命名前缀 SELFZ_ → SELFLNN_VERSION_ 以匹配项目其他模块命名约定 */
#ifndef SELFLNN_VERSION_H
#define SELFLNN_VERSION_H

#define SELFLNN_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define SELFLNN_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define SELFLNN_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define SELFLNN_VERSION_TWEAK @PROJECT_VERSION_TWEAK@

#define SELFLNN_VERSION "@PROJECT_VERSION@"
#define SELFLNN_VERSION_FULL "@PROJECT_VERSION_FULL@"

/* 向后兼容：保留旧宏名供过渡期使用，v2.0移除 */
#define SELFZ_VERSION_MAJOR SELFLNN_VERSION_MAJOR
#define SELFZ_VERSION_MINOR SELFLNN_VERSION_MINOR
#define SELFZ_VERSION_PATCH SELFLNN_VERSION_PATCH
#define SELFZ_VERSION_TWEAK SELFLNN_VERSION_TWEAK
#define SELFZ_VERSION       SELFLNN_VERSION
#define SELFZ_VERSION_FULL  SELFLNN_VERSION_FULL

#endif /* SELFLNN_VERSION_H */
